# ============================================
# 光影校园影像 - 环境变量配置
# ============================================
# 复制此文件为 .env.local 并填入实际值
# Vercel 部署时在项目设置中配置这些变量

# --------------------------------------------
# 对象存储配置（用于上传图片/视频）
# --------------------------------------------
COZE_BUCKET_ENDPOINT_URL=your_s3_endpoint_url
COZE_BUCKET_NAME=your_bucket_name

# --------------------------------------------
# 可选配置
# --------------------------------------------
# NODE_ENV=production
